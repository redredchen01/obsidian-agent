#!/bin/zsh

# YD 2026 — Session Wrap & Auto-sync Aliases
# Source this in ~/.zshrc: source ~/YD\ 2026/.zshrc-wrap

export YD_WORKSPACE="/Users/dex/YD 2026"
export YD_MEMORY="/Users/dex/.claude/projects/-Users-dex-YD-2026/memory"
export YD_OBSIDIAN="$YD_WORKSPACE/obsidian"

# Session Wrap — Save context at session end
alias wrap='bash "$YD_WORKSPACE/session-wrap.sh"'
alias wrap-summary='wrap "$(date +%Y-%m-%d) — Session summary"'

# Auto-sync
alias sync-kb='bash "$YD_WORKSPACE/obsidian-sync.sh"'
alias sync-all='wrap && sync-kb'

# Memory shortcuts
alias mem='cat "$YD_MEMORY/MEMORY.md" | head -50'
alias mem-full='cat "$YD_MEMORY/MEMORY.md"'
alias mem-edit='code "$YD_MEMORY"'

# Status checks
alias yd-km-status='echo "KB: $(find "$YD_OBSIDIAN" -name "*.md" | wc -l) files" && echo "Memory: $(ls -1 "$YD_MEMORY"/*.md 2>/dev/null | wc -l) files"'

# Quick nav
alias kb='code "$YD_OBSIDIAN"'
alias pw='cd "$YD_WORKSPACE" && pwd'

# Session workflow
function yd-start-session() {
    echo "📌 Loading YD 2026 session..."
    echo ""
    echo "Last session wrap:"
    ls -lt "$YD_MEMORY"/session_*_wrap.md 2>/dev/null | head -1 | awk '{print $NF}' | xargs cat 2>/dev/null | head -20
    echo ""
    echo "✅ Ready to work!"
    echo "   Run 'wrap' when done to save context"
}

function yd-end-session() {
    echo "🔄 Ending session..."
    wrap "$@"
    echo ""
    echo "📊 Session saved. Next steps:"
    echo "   1. Review: cat $YD_MEMORY/MEMORY.md"
    echo "   2. Push: cd $YD_WORKSPACE && git push"
}

echo "✅ YD 2026 wrap aliases loaded"
echo "   wrap, sync-kb, mem, kb, yd-start-session, yd-end-session"
