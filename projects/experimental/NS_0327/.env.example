# HR Admin Bot — 環境變數範本
# 複製此檔為 .env 後填入實際值

# Telegram Bot Tokens（透過 @BotFather 建立）
HR_BOT_ONBOARDING_TOKEN=your-onboarding-bot-token
HR_BOT_WORK_PERMIT_TOKEN=your-work-permit-bot-token
HR_BOT_LEAVE_TOKEN=your-leave-bot-token
HR_BOT_OFFBOARDING_TOKEN=your-offboarding-bot-token

# Google Sheets
HR_GOOGLE_SHEET_ID=your-google-sheet-id
HR_GOOGLE_CREDENTIALS_FILE=/app/credentials.json

# SMTP Email
HR_SMTP_HOST=smtp.gmail.com
HR_SMTP_PORT=587
HR_SMTP_USER=hr-bot@company.com
HR_SMTP_PASSWORD=your-smtp-password

# HR 通知收件地址
HR_EMAIL=hr@company.com
