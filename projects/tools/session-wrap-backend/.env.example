# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_wrap_db
DB_USER=postgres
DB_PASSWORD=postgres

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your_super_secret_key_change_in_production

# Claude Code API
CLAUDE_CODE_API_URL=https://api.claude.ai

# Optional: S3/Minio
MINIO_URL=http://localhost:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=session-wraps

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Agent tokens (for testing multi-agent auth)
CLAUDE_CODE_TOKEN=sk_test_your_claude_token
CURSOR_TOKEN=sk_test_your_cursor_token
WINDSURF_TOKEN=sk_test_your_windsurf_token
CLINE_TOKEN=sk_test_your_cline_token
AIDER_TOKEN=sk_test_your_aider_token
