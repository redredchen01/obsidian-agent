# ⚠️  IMPORTANT: Never commit real credentials. This file is a TEMPLATE ONLY.
# Generate strong secrets:
#   JWT_SECRET: openssl rand -base64 32
#   DB_PASSWORD: openssl rand -base64 24

# Database
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<HOST>:5432/<DATABASE>
DB_USER=<postgresql-username>
DB_PASSWORD=<postgresql-password-generated>

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=<generate-32-char-random-string>

# Claude Code API
CLAUDE_CODE_API_URL=https://api.claude.ai

# Optional: S3/Minio
MINIO_URL=https://<minio-host>
MINIO_USER=<minio-username>
MINIO_PASSWORD=<minio-password-generated>
MINIO_BUCKET=session-wraps

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Agent tokens (for testing multi-agent auth)
CLAUDE_CODE_TOKEN=<sk_test_token_or_empty>
CURSOR_TOKEN=<sk_test_token_or_empty>
WINDSURF_TOKEN=<sk_test_token_or_empty>
CLINE_TOKEN=<sk_test_token_or_empty>
AIDER_TOKEN=<sk_test_token_or_empty>

# Redis (optional, for caching)
REDIS_URL=redis://<redis-host>:6379

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<YOUR_WEBHOOK>

# GitHub Integration
GITHUB_TOKEN=<ghp_your_token>
GITHUB_OWNER=<owner>
GITHUB_REPO=<repo>

# Jira Integration
JIRA_HOST=https://<your-domain>.atlassian.net
JIRA_EMAIL=<email@example.com>
JIRA_API_TOKEN=<jira_token>
JIRA_PROJECT_KEY=<PROJ>
